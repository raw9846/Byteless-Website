{
  "name": "alamra-website-mailer",
  "main": "worker.js",
  "compatibility_date": "2026-01-12",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "logs": {
      "enabled": false,
      "head_sampling_rate": 1,
      "invocation_logs": true,
      "persist": true
    }
  }
}